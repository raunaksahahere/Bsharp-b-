note Dictionary and nested data demo

let person be dictionary with
    name as "Raunak"
    age as 21
    city as "Mumbai"
end

say "Person data:", person
explain

let scores be list of 95, 87, 92, 78, 88
let total be 0
for each score in scores do
    change total to total plus score
end

let count be get length of scores
say "Total score:", total
say "Number of scores:", count
say "Average:", total divided by count