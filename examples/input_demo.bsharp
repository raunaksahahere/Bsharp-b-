note Interactive input demonstration

say "Welcome to the B# Name Greeter!"
ask "What is your name?" and store in name
ask "How old are you?" as integer and store in age

say "Hello,", name
say "You are", age, "years old."

if age is at least 18 then
    say "You are an adult."
else
    say "You are a minor."
end

let next_year be age plus 1
say "Next year you will be", next_year