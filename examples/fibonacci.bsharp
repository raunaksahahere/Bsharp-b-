note Fibonacci sequence using recursion

define function fibonacci with n do
    if n is less than 2 then
        return n
    end
    let a be call fibonacci with n minus 1
    let b be call fibonacci with n minus 2
    return a plus b
end

say "Fibonacci sequence (0 to 10):"
for each i from 0 to 10 do
    let result be call fibonacci with i
    say i, "->", result
end