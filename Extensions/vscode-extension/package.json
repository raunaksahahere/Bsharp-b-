{
  "name": "bsharp",
  "displayName": "B# Language",
  "description": "Syntax highlighting for the B# programming language (.bsharp files)",
  "version": "1.0.0",
  "publisher": "bsharp-lang",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "bsharp",
        "aliases": ["B#", "bsharp", "B-sharp"],
        "extensions": [".bsharp"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bsharp",
        "scopeName": "source.bsharp",
        "path": "./syntaxes/bsharp.tmLanguage.json"
      }
    ]
  }
}